<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nutritrack"
        tools:targetApi="31">
        <activity
            android:name=".presentation.activities.UserDetailsActivity"
            android:exported="false"
            android:label="@string/title_activity_user_details"
            android:theme="@style/Theme.Nutritrack" />
        <activity
            android:name=".presentation.activities.ClinicianActivity"
            android:exported="false"
            android:label="@string/title_activity_clinician_screen"
            android:theme="@style/Theme.Nutritrack" />
        <activity
            android:name=".presentation.activities.NutricoachActivity"
            android:exported="false"
            android:label="@string/title_activity_nutricoach_screen"
            android:theme="@style/Theme.Nutritrack" />
        <activity
            android:name=".presentation.activities.SettingsActivity"
            android:exported="false"
            android:label="@string/title_activity_settings_screen"
            android:theme="@style/Theme.Nutritrack" />
        <activity
            android:name=".presentation.activities.InsightsActivity"
            android:exported="false"
            android:label="@string/title_activity_insights_screen"
            android:theme="@style/Theme.Nutritrack" />
        <activity
            android:name=".presentation.activities.HomeActivity"
            android:exported="false"
            android:label="@string/title_activity_home_screen"
            android:theme="@style/Theme.Nutritrack" />
        <activity
            android:name=".presentation.activities.QuestionnaireActivity"
            android:exported="false"
            android:label="@string/title_activity_food_intake_questionnaire"
            android:theme="@style/Theme.Nutritrack" />
        <activity
            android:name=".presentation.activities.LoginActivity"
            android:exported="false"
            android:label="@string/title_activity_login_screen"
            android:theme="@style/Theme.Nutritrack" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Nutritrack">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>